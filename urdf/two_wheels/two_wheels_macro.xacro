<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:include filename="$(find two_wheels)/urdf/common.xacro"/>

    <xacro:property name="disc_height" value="0.005"/>
    <xacro:property name="disc_radius" value="0.07"/>
    <xacro:property name="disc_mass" value="0.05"/>


    <xacro:property name="wheel_width" value="0.025"/>
    <xacro:property name="wheel_radius" value="0.033"/>
    <xacro:property name="wheel_mass" value="0.01"/>

    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <xacro:macro name="wheel" params="prefix y_reflect">
        <link name="${prefix}_wheel">
            <visual>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="black">
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            <xacro:cylinder_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}" rotation="${pi/2}"/>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_wheel"/>
            <origin xyz="0 ${y_reflect*(disc_radius+(wheel_width/2))} ${wheel_radius}" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
        </joint>
    </xacro:macro>

    <xacro:macro name="two_wheels" >
        <link name="base_link">
            <xacro:cylinder_inertial mass="${disc_mass}" radius="${disc_radius}" length="${disc_height}" rotation="0"/>
            <visual>
                <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${disc_radius}" length="${disc_height}"/>
                </geometry>

                <material name="white"/>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <cylinder radius="${disc_radius}" length="${disc_height}"/>
                </geometry>
            </collision>
        </link>

<!--        <joint name="base_joint" type="fixed">-->
<!--            <parent link="base_footprint"/>-->
<!--            <child link="base_link"/>-->
<!--            <origin xyz="0.0 0.0 ${-wheel_radius}" rpy="0 0 0"/>-->
<!--        </joint>-->

        <xacro:wheel prefix="left" y_reflect="1"/>
        <xacro:wheel prefix="right" y_reflect="-1"/>

        <gazebo reference="base_link">
            <material>Gazebo/White</material>
        </gazebo>
        <gazebo reference="left_wheel">
            <material>Gazebo/Black</material>
        </gazebo>
        <gazebo reference="right_wheel">
            <material>Gazebo/Black</material>
        </gazebo>

    </xacro:macro>
</robot>
